# Gateway
NGINX_PORT=11946

# API
API_PORT=8080
NODE_ENV=development

# Auth
PAN_ADMIN_USERNAME=admin
# Required. Used to sign and verify the Web cookie session token.
WEB_SESSION_SECRET=change_me_session_secret
# Required when Web login is enabled. Example generated by:
# htpasswd -nbBC 10 '' 'change-this-password' | cut -d: -f2
# In the Compose root `.env`, keep single quotes so Docker Compose treats `$`
# as a literal and does not try to interpolate the bcrypt payload.
AUTH_PASSWORD_HASH_BCRYPT='$2y$10$JVqLor5i8Rbmt3vVCXWFLeuodmL02vQUfIvWFOw.1uggVgWoZM0Xy'
# Required for App JWT auth. Copy `configs/local-public-key.example.pem` to
# `configs/local-public-key.pem` and replace it with your real RSA public key.
# Relative paths are resolved from the `.env` directory.
APP_AUTH_LOCAL_PUBLIC_KEY_FILE=./configs/local-public-key.pem

# Storage
# 运行时数据统一落在仓库根目录 ./data。
PAN_DATA_DIR=./data
# 挂载点改为放在 configs/mounts/*.json；PAN_MOUNTS 仅保留兼容兜底，不再推荐。

# Limits
# 单次上传总大小限制，单位字节；默认 20 MB。
MAX_UPLOAD_BYTES=20971520
MAX_EDIT_FILE_BYTES=1048576
