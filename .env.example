# App
APP_PORT=8080
WEB_ORIGIN=http://127.0.0.1:5173
PAN_STATIC_DIR=

# Auth
PAN_ADMIN_USERNAME=admin
PAN_ADMIN_PASSWORD=change_me
WEB_SESSION_SECRET=change_me_session_secret
APP_TOKEN_SIGNING_KEY=change_me_app_token_secret

# Storage
# 运行时数据统一落在仓库根目录 ./data。
PAN_DATA_DIR=./data
PAN_MOUNTS=home|Home|/Users/yourname

# Limits
MAX_UPLOAD_BYTES=104857600
MAX_EDIT_FILE_BYTES=1048576
