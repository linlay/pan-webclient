# App
WEB_PORT=11946
APP_PORT=11936
# Optional. Only needed for dev-time CORS when frontend and backend are on different origins.
NODE_ENV=development
WEB_ORIGIN=http://127.0.0.1:11946
SERVER_ORIGIN=http://127.0.0.1:11936
PAN_STATIC_DIR=

# Auth
PAN_ADMIN_USERNAME=admin
# Required. Used to sign and verify the Web cookie session token.
WEB_SESSION_SECRET=change_me_session_secret
# Required when Web login is enabled. Example generated by:
# htpasswd -nbBC 10 '' 'change-this-password' | cut -d: -f2
AUTH_PASSWORD_HASH_BCRYPT='$2y$10$qvVeaEjEXOJO5ajAU2hxa.syfhsS96nNNlKmDxDWtuCZraAJyxy3q'
# Required. Copy configs/local-public-key.example.pem to configs/local-public-key.pem and replace it with your real RSA public key.
AUTH_APP_PUBLIC_KEY_FILE=./configs/local-public-key.pem

# Storage
# 运行时数据统一落在仓库根目录 ./data。
PAN_DATA_DIR=./data
# 挂载点改为放在 configs/mounts/*.json；PAN_MOUNTS 仅保留兼容兜底，不再推荐。

# Limits
MAX_UPLOAD_BYTES=104857600
MAX_EDIT_FILE_BYTES=1048576
